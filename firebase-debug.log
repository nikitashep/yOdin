[debug] [2026-06-12T11:53:56.790Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/yodin-23362/rulesets {"name":"projects/yodin-23362/rulesets/592e1fd5-b6ca-4750-a389-3cfd90665957","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Users — only the owner can write their own profile.\n    // Exception: anyone can increment points by exactly 1 (accepted answer award).\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth != null && request.auth.uid == userId;\n      allow update: if request.auth != null\n        && onlyUpdatingField(request, 'points')\n        && request.resource.data.points == resource.data.get('points', 0) + 1;\n    }\n\n    // Posts — event feed cards; authenticated users can read and create\n    match /posts/{postId} {\n      allow read: if request.auth != null;\n      allow create: if request.auth != null\n        && request.resource.data.authorId == request.auth.uid\n        && request.resource.data.title is string\n        && request.resource.data.title.size() > 0\n        && request.resource.data.title.size() <= 100\n        && request.resource.data.description is string\n        && request.resource.data.description.size() > 0\n        && request.resource.data.description.size() <= 1000\n        && request.resource.data.category in ['news', 'events', 'places'];\n      allow update, delete: if request.auth != null\n        && resource.data.authorId == request.auth.uid;\n    }\n\n    // Discussions form per-nationality forums: a discussion belongs to its\n    // author's nationality (authorCountryCode). Only users of the SAME\n    // nationality may read it, post it, or reply to it.\n    match /discussions/{discussionId} {\n      // Read your nationality's forum, plus your own questions and the ones you\n      // saved (so the profile tabs keep working even after a nationality change).\n      allow read: if canAccessDiscussion(resource.data);\n      allow create: if request.auth != null\n        && request.resource.data.authorId == request.auth.uid\n        && request.resource.data.authorCountryCode == myNationality()\n        && request.resource.data.question is string\n        && request.resource.data.question.size() > 0\n        && request.resource.data.question.size() <= 500;\n      allow update: if request.auth != null\n        && (\n          resource.data.authorId == request.auth.uid\n          || savedByUpdate()\n          || replyCountUpdate()\n        );\n      allow delete: if request.auth != null\n        && resource.data.authorId == request.auth.uid;\n\n      // Replies — readable by anyone who can access the discussion; only\n      // same-nationality users may post (answer) in it.\n      match /replies/{replyId} {\n        allow read: if canAccessDiscussion(discussionData(discussionId));\n        allow create: if request.auth != null\n          && request.resource.data.authorId == request.auth.uid\n          && sameNationality(discussionData(discussionId).authorCountryCode)\n          && request.resource.data.text is string\n          && request.resource.data.text.size() > 0\n          && request.resource.data.text.size() <= 1000;\n        // Votes: users may only add/remove their own UID in likes/dislikes\n        allow update: if request.auth != null\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])\n          && ownUidArrayChange(resource.data.get('likes', []), request.resource.data.get('likes', []))\n          && ownUidArrayChange(resource.data.get('dislikes', []), request.resource.data.get('dislikes', []));\n        allow delete: if request.auth != null\n          && resource.data.authorId == request.auth.uid;\n      }\n    }\n\n    // Notifications — recipient can read/update; only the authenticated sender can create\n    match /notifications/{notificationId} {\n      allow read: if request.auth != null\n        && resource.data.toUserId == request.auth.uid;\n      allow update: if request.auth != null\n        && resource.data.toUserId == request.auth.uid\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);\n      allow create: if request.auth != null\n        && request.resource.data.fromUserId == request.auth.uid\n        && request.resource.data.toUserId is string\n        && request.resource.data.discussionId is string\n        && request.resource.data.discussionQuestion is string;\n    }\n\n    // savedBy update: user can only add or remove their own UID. Adding is\n    // restricted to the user's own nationality so saving can't be used to gain\n    // read access to another nationality's discussion; removing is always allowed.\n    function savedByUpdate() {\n      let before = resource.data.get('savedBy', []);\n      let after = request.resource.data.get('savedBy', []);\n      let uid = request.auth.uid;\n      let diff = onlyUpdatingField(request, 'savedBy');\n      let adding = after.hasAll(before) && after.removeAll(before) == [uid]\n        && sameNationality(resource.data.authorCountryCode);\n      let removing = before.hasAll(after) && before.removeAll(after) == [uid];\n      return diff && (adding || removing);\n    }\n\n    // replyCount update: can only increment by exactly 1\n    function replyCountUpdate() {\n      return onlyUpdatingField(request, 'replyCount')\n        && request.resource.data.replyCount == resource.data.replyCount + 1;\n    }\n\n    function onlyUpdatingField(req, field) {\n      return req.resource.data.diff(resource.data).affectedKeys().hasOnly([field]);\n    }\n\n    // The signed-in user's own nationality code (from their user document).\n    function myNationality() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.countryCode;\n    }\n\n    // The full data of a discussion document by id.\n    function discussionData(discussionId) {\n      return get(/databases/$(database)/documents/discussions/$(discussionId)).data;\n    }\n\n    // True when the signed-in user shares the given nationality code.\n    function sameNationality(code) {\n      return request.auth != null && myNationality() == code;\n    }\n\n    // A user may access a discussion when it's in their nationality forum, or\n    // they authored it, or they previously saved it.\n    function canAccessDiscussion(d) {\n      return request.auth != null && (\n        myNationality() == d.authorCountryCode\n        || d.authorId == request.auth.uid\n        || request.auth.uid in d.get('savedBy', [])\n      );\n    }\n\n    // Array may stay the same, or differ only by the requester's own UID\n    function ownUidArrayChange(before, after) {\n      let uid = request.auth.uid;\n      return before == after\n        || (after.hasAll(before) && after.removeAll(before) == [uid])\n        || (before.hasAll(after) && before.removeAll(after) == [uid]);\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-12T11:53:57.371279Z","metadata":{"services":["cloud.firestore"]}}
