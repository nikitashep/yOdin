rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the owner can write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Discussions — authenticated users can read and create
    // Only the author can delete their own discussion
    match /discussions/{discussionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.question is string
        && request.resource.data.question.size() > 0
        && request.resource.data.question.size() <= 500;
      allow update: if request.auth != null
        && (
          resource.data.authorId == request.auth.uid
          || savedByUpdate()
          || replyCountUpdate()
        );
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Replies — authenticated users can read and create
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
      }
    }

    // Notifications — recipient can read/update; only the authenticated sender can create
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null
        && resource.data.toUserId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.discussionId is string
        && request.resource.data.discussionQuestion is string;
    }

    // savedBy update: user can only add or remove their own UID from the array
    function savedByUpdate() {
      let before = resource.data.savedBy;
      let after = request.resource.data.savedBy;
      let uid = request.auth.uid;
      let diff = onlyUpdatingField(request, 'savedBy');
      let adding = after.hasAll(before) && after.removeAll(before) == [uid];
      let removing = before.hasAll(after) && before.removeAll(after) == [uid];
      return diff && (adding || removing);
    }

    // replyCount update: can only increment by exactly 1
    function replyCountUpdate() {
      return onlyUpdatingField(request, 'replyCount')
        && request.resource.data.replyCount == resource.data.replyCount + 1;
    }

    function onlyUpdatingField(req, field) {
      return req.resource.data.diff(resource.data).affectedKeys().hasOnly([field]);
    }
  }
}
