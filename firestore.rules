rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the owner can write their own profile.
    // Exception: anyone can increment points by exactly 1 (accepted answer award).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && onlyUpdatingField(request, 'points')
        && request.resource.data.points == resource.data.get('points', 0) + 1;
    }

    // Posts — event feed cards; authenticated users can read and create
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 1000
        && request.resource.data.category in ['news', 'events', 'places'];
      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    // Discussions form per-nationality forums: a discussion belongs to its
    // author's nationality (authorCountryCode). Only users of the SAME
    // nationality may read it, post it, or reply to it.
    match /discussions/{discussionId} {
      // Read your nationality's forum, plus your own questions and the ones you
      // saved (so the profile tabs keep working even after a nationality change).
      allow read: if canAccessDiscussion(resource.data);
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorCountryCode == myNationality()
        && request.resource.data.question is string
        && request.resource.data.question.size() > 0
        && request.resource.data.question.size() <= 500;
      allow update: if request.auth != null
        && (
          resource.data.authorId == request.auth.uid
          || savedByUpdate()
          || replyCountUpdate()
        );
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Replies — readable by anyone who can access the discussion; only
      // same-nationality users may post (answer) in it.
      match /replies/{replyId} {
        allow read: if canAccessDiscussion(discussionData(discussionId));
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && sameNationality(discussionData(discussionId).authorCountryCode)
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        // Votes: users may only add/remove their own UID in likes/dislikes
        allow update: if request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
          && ownUidArrayChange(resource.data.get('likes', []), request.resource.data.get('likes', []))
          && ownUidArrayChange(resource.data.get('dislikes', []), request.resource.data.get('dislikes', []));
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
      }
    }

    // Notifications — recipient can read/update; only the authenticated sender can create
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.toUserId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.discussionId is string
        && request.resource.data.discussionQuestion is string;
    }

    // savedBy update: user can only add or remove their own UID. Adding is
    // restricted to the user's own nationality so saving can't be used to gain
    // read access to another nationality's discussion; removing is always allowed.
    function savedByUpdate() {
      let before = resource.data.get('savedBy', []);
      let after = request.resource.data.get('savedBy', []);
      let uid = request.auth.uid;
      let diff = onlyUpdatingField(request, 'savedBy');
      let adding = after.hasAll(before) && after.removeAll(before) == [uid]
        && sameNationality(resource.data.authorCountryCode);
      let removing = before.hasAll(after) && before.removeAll(after) == [uid];
      return diff && (adding || removing);
    }

    // replyCount update: can only increment by exactly 1
    function replyCountUpdate() {
      return onlyUpdatingField(request, 'replyCount')
        && request.resource.data.replyCount == resource.data.replyCount + 1;
    }

    function onlyUpdatingField(req, field) {
      return req.resource.data.diff(resource.data).affectedKeys().hasOnly([field]);
    }

    // The signed-in user's own nationality code (from their user document).
    function myNationality() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.countryCode;
    }

    // The full data of a discussion document by id.
    function discussionData(discussionId) {
      return get(/databases/$(database)/documents/discussions/$(discussionId)).data;
    }

    // True when the signed-in user shares the given nationality code.
    function sameNationality(code) {
      return request.auth != null && myNationality() == code;
    }

    // A user may access a discussion when it's in their nationality forum, or
    // they authored it, or they previously saved it.
    function canAccessDiscussion(d) {
      return request.auth != null && (
        myNationality() == d.authorCountryCode
        || d.authorId == request.auth.uid
        || request.auth.uid in d.get('savedBy', [])
      );
    }

    // Array may stay the same, or differ only by the requester's own UID
    function ownUidArrayChange(before, after) {
      let uid = request.auth.uid;
      return before == after
        || (after.hasAll(before) && after.removeAll(before) == [uid])
        || (before.hasAll(after) && before.removeAll(after) == [uid]);
    }
  }
}
