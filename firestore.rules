rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — owner can update their own profile fields but NOT points.
    // Points are awarded exclusively by the system (accepted-reply batch).
    match /users/{userId} {
      allow read: if request.auth != null;
      // New profiles must start with zero points — they're earned, not self-set.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.points == 0;
      allow delete: if request.auth != null && request.auth.uid == userId;
      // Owner may update any field except points/uid/createdAt (immutable or system-managed)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['points', 'uid', 'createdAt']);
      // Points are awarded exclusively by the onDiscussionUpdated Cloud Function
      // (Admin SDK), which bypasses these rules. There is deliberately NO client
      // path to mutate points — the old "+1 by anyone" rule was farmable.
    }

    // Posts — location-scoped event feed cards.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && isVerified()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.feedScore == 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 1000
        && request.resource.data.category in ['news', 'events', 'places', 'lifestyle']
        // A sign-up sheet is only valid on events and must start with an empty
        // participant list — the author can't pre-fill attendees.
        && (
          request.resource.data.get('signupEnabled', false) == false
          || (request.resource.data.category == 'events'
              && request.resource.data.get('participants', []) == [])
        );
      allow update: if request.auth != null
        && (
          postVoteUpdate()
          || postSavedByUpdate()
          || participantsUpdate()
        );
      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid || isModerator());

      // Comments — any authenticated user can read and post a comment
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && isVerified()
          && notBlocked()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid || isModerator());
      }
    }

    // Discussions — global Q&A forum (visible across regions/nationalities).
    // `location` is still stamped on each doc for a future country filter.
    match /discussions/{discussionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && isVerified()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.feedScore == 0
        && request.resource.data.engagement == 0
        && request.resource.data.location == myLocation()
        && request.resource.data.question is string
        && request.resource.data.question.size() > 0
        && request.resource.data.question.size() <= 500;
      // Update is restricted to three specific operations — no free-form author update.
      allow update: if request.auth != null
        && (
          acceptedReplyUpdate()
          || savedByUpdate()
        );
      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid || isModerator());

      // Replies — any authenticated user may read and post (global forum).
      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && isVerified()
          && notBlocked()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          // Once the question author accepts an answer the thread is closed —
          // no further replies (enforced here so it can't be bypassed via API).
          && get(/databases/$(database)/documents/discussions/$(discussionId)).data.get('acceptedReplyId', null) == null;
        // Votes: users may only add/remove their own UID in likes/dislikes
        allow update: if request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
          && ownUidArrayChange(resource.data.get('likes', []), request.resource.data.get('likes', []))
          && ownUidArrayChange(resource.data.get('dislikes', []), request.resource.data.get('dislikes', []));
        allow delete: if request.auth != null
          && (resource.data.authorId == request.auth.uid || isModerator());
      }
    }

    // Notifications — recipient reads/marks read/deletes; sender creates.
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.toUserId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if request.auth != null
        && resource.data.toUserId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.fromUserName is string
        && request.resource.data.fromUserName.size() <= 100
        && (
          // Forum notification (reply / accepted answer).
          (request.resource.data.discussionId is string
            && request.resource.data.discussionQuestion is string
            && request.resource.data.discussionQuestion.size() <= 500)
          // Event sign-up notification.
          || (request.resource.data.type == 'participant'
            && request.resource.data.postId is string
            && request.resource.data.postTitle is string
            && request.resource.data.postTitle.size() <= 100)
        );
    }

    // Reports — any signed-in user can file one; only moderators can see and act on them.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && isVerified()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.targetType in ['post', 'discussion', 'comment', 'reply']
        && request.resource.data.targetId is string
        && request.resource.data.status == 'pending';
      allow read, update, delete: if isModerator();
    }

    // Moderator status is carried by a Firebase custom claim on the ID token.
    function isModerator() {
      return request.auth != null && request.auth.token.moderator == true;
    }

    // Email verification is mandatory to contribute content. The flag lives on
    // the signed ID token, so it can't be spoofed by the client.
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Comment/reply ban: the onReportUpdated function sets commentBlockedUntil
    // (epoch ms) on a user after repeated moderator-confirmed removals. While
    // that time is in the future the user can't post comments or replies.
    function notBlocked() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('commentBlockedUntil', 0) < request.time.toMillis();
    }

    // acceptedReplyId: only the question author may set it, and only once (immutable once answered).
    // The accepted answer text/author are denormalized alongside it so the forum
    // feed can render the answer without an extra read.
    function acceptedReplyUpdate() {
      return resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['acceptedReplyId', 'acceptedReplyText', 'acceptedReplyAuthorName'])
        && resource.data.get('acceptedReplyId', null) == null;
    }

    // savedBy update: user can only add or remove their own UID.
    function savedByUpdate() {
      return onlyUpdatingField(request, 'savedBy')
        && ownUidArrayChange(resource.data.get('savedBy', []), request.resource.data.get('savedBy', []));
    }

    // Post save: a user may only add/remove their own UID in savedBy.
    function postSavedByUpdate() {
      return onlyUpdatingField(request, 'savedBy')
        && ownUidArrayChange(resource.data.get('savedBy', []), request.resource.data.get('savedBy', []));
    }

    // Event RSVP: a user may only add/remove their own UID in participants, and
    // only while the cap (if any) isn't exceeded. Leaving is always allowed.
    function participantsUpdate() {
      return onlyUpdatingField(request, 'participants')
        && resource.data.get('signupEnabled', false) == true
        && ownUidArrayChange(resource.data.get('participants', []), request.resource.data.get('participants', []))
        && (
          request.resource.data.participants.size() <= resource.data.get('participants', []).size()
          || resource.data.get('participantLimit', null) == null
          || request.resource.data.participants.size() <= resource.data.participantLimit
        );
    }

    // Post vote: a user may only add/remove their own UID in likes/dislikes
    function postVoteUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
        && ownUidArrayChange(resource.data.get('likes', []), request.resource.data.get('likes', []))
        && ownUidArrayChange(resource.data.get('dislikes', []), request.resource.data.get('dislikes', []));
    }

    function onlyUpdatingField(req, field) {
      return req.resource.data.diff(resource.data).affectedKeys().hasOnly([field]);
    }

    function myLocation() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.location;
    }

    function ownUidArrayChange(before, after) {
      let uid = request.auth.uid;
      return before == after
        || (after.hasAll(before) && after.removeAll(before) == [uid])
        || (before.hasAll(after) && before.removeAll(after) == [uid]);
    }
  }
}
