{
  "expo": {
    "name": "yOdin",
    "slug": "yodin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C35DE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "az.birklik.yodin"
    },
    "android": {
      "package": "az.birklik.yodin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C35DE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow yOdin to access your photos to attach them to discussions and posts.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-localization"
    ]
  }
}
